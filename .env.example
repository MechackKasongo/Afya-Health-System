# ==============================
# Afya Health System - Env vars
# ==============================

# --- Profils Spring ---
# Défaut (sans cette variable) = profil dev = H2 en mémoire (pas d'Oracle requis).
# Pour Oracle + Flyway : décommentez et démarrez avec ce profil.
# SPRING_PROFILES_ACTIVE=oracle

# --- Oracle (uniquement si SPRING_PROFILES_ACTIVE=oracle) ---
ORACLE_URL=jdbc:oracle:thin:@//localhost:1521/XEPDB1
ORACLE_USERNAME=afya
ORACLE_PASSWORD=change-me

# --- Flyway (profil oracle) : désactiver si premier boot Hibernate seul sur BASE VIDE ---
# SPRING_FLYWAY_ENABLED=false

# --- JWT secrets (min 64 chars) ---
JWT_ACCESS_SECRET=replace-with-your-very-long-access-secret-at-least-64-characters-000000
JWT_REFRESH_SECRET=replace-with-your-very-long-refresh-secret-at-least-64-characters-111111
JWT_ACCESS_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=2592000

# --- Bootstrap user (temporaire) ---
APP_BOOTSTRAP_USERNAME=admin
APP_BOOTSTRAP_FULL_NAME=Administrateur AFYA
APP_BOOTSTRAP_PASSWORD=change-me
APP_BOOTSTRAP_ROLES=ROLE_ADMIN
